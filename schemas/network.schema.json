{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Abhaile Network Configuration",
  "description": "Network topology including VLANs, hosts, services, and DNS",
  "type": "object",
  "properties": {
    "vlans": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9_-]*$": {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4094
            },
            "cidr": {
              "type": "string",
              "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$"
            },
            "gateway": {
              "type": "string",
              "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}$"
            },
            "ipvlanl2_range": {
              "type": "string",
              "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}-([0-9]{1,3}\\.){3}[0-9]{1,3}$"
            }
          },
          "required": ["id", "cidr", "gateway"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "dns": {
      "type": "object",
      "properties": {
        "zones": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "provider": {
                "type": "string"
              },
              "serial": {
                "type": "object",
                "properties": {
                  "date": {
                    "type": "integer",
                    "pattern": "^[0-9]{8}$"
                  },
                  "counter": {
                    "type": "integer",
                    "pattern": "^[0-9]{2}$"
                  },
                  "content_hash": {
                    "type": ["string", "null"]
                  }
                },
                "required": ["date", "counter", "content_hash"],
                "additionalProperties": false
              }
            },
            "required": ["name", "provider"],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "hosts": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9-]*$": {
          "type": "object",
          "properties": {
            "physical_device": {
              "type": "string",
              "pattern": "^[a-z0-9]+$"
            },
            "interfaces": {
              "type": "object",
              "patternProperties": {
                "^[a-z0-9.-]+$": {
                  "type": "object",
                  "properties": {
                    "address": {
                      "type": "string",
                      "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$"
                    },
                    "vlan": {
                      "type": "string"
                    }
                  },
                  "required": ["address", "vlan"],
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "dns": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "zone": {
                    "type": "string"
                  },
                  "records": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": ["a", "aaaa", "cname", "mx", "txt", "srv", "ptr"]
                        },
                        "name": {
                          "type": "string"
                        },
                        "rdata": {
                          "type": "string"
                        },
                        "ptr": {
                          "type": "boolean"
                        }
                      },
                      "required": ["type", "name", "rdata"],
                      "additionalProperties": false
                    }
                  }
                },
                "required": ["zone", "records"],
                "additionalProperties": false
              }
            }
          },
          "required": ["physical_device", "interfaces"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "services": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9-]*$": {
          "type": "object",
          "properties": {
            "address": {
              "type": "string",
              "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$"
            },
            "vlan": {
              "type": "string"
            },
            "dns": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "zone": {
                    "type": "string"
                  },
                  "records": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": ["a", "aaaa", "cname", "mx", "txt", "srv", "ptr"]
                        },
                        "name": {
                          "type": "string"
                        },
                        "rdata": {
                          "type": "string"
                        },
                        "ptr": {
                          "type": "boolean"
                        }
                      },
                      "required": ["type", "name", "rdata"],
                      "additionalProperties": false
                    }
                  }
                },
                "required": ["zone", "records"],
                "additionalProperties": false
              }
            }
          },
          "required": ["address", "vlan"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["vlans", "hosts"],
  "additionalProperties": false
}
