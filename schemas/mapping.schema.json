{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Abhaile Mapping Configuration",
  "description": "Maps services to hosts for GitOps deployment",
  "type": "object",
  "properties": {
    "abhaile": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "propertyNames": {
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      }
    }
  },
  "required": ["abhaile"],
  "additionalProperties": false
}
