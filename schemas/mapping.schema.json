{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Abhaile Mapping Schema",
  "description": "Schema for config/mapping.yaml - defines host-to-service assignments",
  "type": "object",
  "required": ["abhaile"],
  "properties": {
    "abhaile": {
      "type": "array",
      "description": "List of hosts in the Abhaile cluster",
      "minItems": 1,
      "items": {
        "type": "object",
        "minProperties": 1,
        "maxProperties": 1,
        "additionalProperties": {
          "type": "array",
          "description": "List of services running on this host",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "description": "Service name"
              },
              {
                "type": "object",
                "description": "Service with optional configuration",
                "additionalProperties": true
              }
            ]
          }
        }
      }
    }
  },
  "additionalProperties": false
}
