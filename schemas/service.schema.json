{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Abhaile Service Schema",
  "description": "Schema for config/services/*/service.yaml - defines service configuration",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Service name (should match directory name)"
    },
    "type": {
      "type": "string",
      "enum": ["pod", "container", "host"],
      "description": "Service type: pod (multi-container), container (single), or host (systemd services)"
    },
    "mode": {
      "type": "string",
      "enum": ["rootful", "rootless", ""],
      "description": "Privilege mode: rootful, rootless, or empty string for host services"
    },
    "network": {
      "type": "string",
      "oneOf": [
        {"enum": ["ipvlan-l2", "service-32", "host"]},
        {"pattern": "^container:.+"}
      ],
      "description": "Network mode: ipvlan-l2, service-32, host, or container:<name>"
    },
    "config": {
      "type": "array",
      "description": "Configuration files to deploy",
      "items": {
        "type": "object",
        "required": ["destination"],
        "properties": {
          "source": {
            "oneOf": [
              {
                "type": "string",
                "description": "Static source file path"
              },
              {
                "type": "object",
                "description": "Template source with variables",
                "required": ["template"],
                "properties": {
                  "template": {
                    "type": "string",
                    "description": "Jinja2 template path"
                  },
                  "variables": {
                    "type": "object",
                    "description": "Template variables (values may contain placeholders like %%services.caddy-dmz.address%%)"
                  }
                },
                "additionalProperties": false
              }
            ]
          },
          "destination": {
            "type": "string",
            "description": "Destination path in the service (e.g., /srv/authelia/config/)"
          }
        },
        "additionalProperties": false
      }
    },
    "vault_agent": {
      "type": "object",
      "description": "Vault Agent configuration for secret injection",
      "properties": {
        "templates": {
          "type": "array",
          "description": "Vault Agent templates to render",
          "items": {
            "type": "object",
            "required": ["source", "out"],
            "properties": {
              "source": {
                "type": "string",
                "description": "Template source path (.ctmpl file)"
              },
              "out": {
                "type": "string",
                "description": "Output filename"
              },
              "perms": {
                "type": "string",
                "pattern": "^0[0-7]{3}$",
                "description": "File permissions (e.g., 0640)"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "ingress": {
      "type": "object",
      "description": "Caddy ingress/reverse proxy configuration",
      "additionalProperties": {
        "type": "array",
        "description": "Ingress rules for a domain",
        "items": {
          "type": "object",
          "properties": {
            "block": {
              "type": "string",
              "description": "Caddy config block file path"
            },
            "base": {
              "type": "string",
              "description": "Base Caddyfile path"
            },
            "destination": {
              "type": "string",
              "description": "Destination path for Caddyfile"
            }
          },
          "additionalProperties": false
        }
      }
    },
    "pod": {
      "type": "object",
      "description": "Pod configuration (for type: pod)",
      "properties": {
        "containers": {
          "type": "array",
          "description": "Container definitions within the pod",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Container name"
              },
              "named_volumes": {
                "type": "array",
                "description": "Named volumes to mount in this container",
                "items": {
                  "type": "object",
                  "required": ["name", "host", "mount"],
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Volume name"
                    },
                    "host": {
                      "type": "string",
                      "description": "Host path"
                    },
                    "mount": {
                      "type": "string",
                      "description": "Container mount path"
                    },
                    "mode": {
                      "type": "string",
                      "enum": ["ro", "rw"],
                      "description": "Mount mode (ro=read-only, rw=read-write)"
                    },
                    "shared": {
                      "type": "boolean",
                      "description": "Whether volume is shared between containers"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "mounted_files": {
                "type": "array",
                "description": "Individual files to mount",
                "items": {
                  "type": "object",
                  "required": ["host", "mount"],
                  "properties": {
                    "host": {
                      "type": "string",
                      "description": "Host file path"
                    },
                    "mount": {
                      "type": "string",
                      "description": "Container mount path"
                    },
                    "mode": {
                      "type": "string",
                      "enum": ["ro", "rw"],
                      "description": "Mount mode"
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "container": {
      "type": "object",
      "description": "Container configuration (for type: container)",
      "properties": {
        "named_volumes": {
          "type": "array",
          "description": "Named volumes to mount",
          "items": {
            "type": "object",
            "required": ["name", "host", "mount"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Volume name"
              },
              "host": {
                "type": "string",
                "description": "Host path"
              },
              "mount": {
                "type": "string",
                "description": "Container mount path"
              },
              "mode": {
                "type": "string",
                "enum": ["ro", "rw"],
                "description": "Mount mode"
              },
              "shared": {
                "type": "boolean",
                "description": "Whether volume is shared"
              }
            },
            "additionalProperties": false
          }
        },
        "mounted_files": {
          "type": "array",
          "description": "Individual files to mount",
          "items": {
            "type": "object",
            "required": ["host", "mount"],
            "properties": {
              "host": {
                "type": "string",
                "description": "Host file path"
              },
              "mount": {
                "type": "string",
                "description": "Container mount path"
              },
              "mode": {
                "type": "string",
                "enum": ["ro", "rw"],
                "description": "Mount mode"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "include": {
      "type": "array",
      "description": "Include other service configurations",
      "items": {
        "type": "string"
      }
    },
    "rootless_user": {
      "type": "string",
      "description": "User to run rootless container/service as"
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["type"],
        "properties": {
          "type": {"const": "host"}
        }
      },
      "then": {
        "required": ["mode", "network"],
        "properties": {
          "mode": {"const": ""},
          "network": {"enum": ["host", "service-32"]}
        }
      }
    },
    {
      "if": {
        "required": ["type"],
        "properties": {
          "type": {"enum": ["container", "pod"]}
        }
      },
      "then": {
        "required": ["mode", "network"],
        "properties": {
          "mode": {"enum": ["rootful", "rootless"]},
          "network": {
            "oneOf": [
              {"enum": ["ipvlan-l2", "host"]},
              {"pattern": "^container:.+"}
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
