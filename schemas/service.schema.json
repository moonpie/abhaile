{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Abhaile Service Schema",
  "description": "Schema for config/services/*/service.yaml - defines service configuration",
  "type": "object",
  "definitions": {
    "serviceConfigSource": {
      "oneOf": [
        {
          "type": "string",
          "description": "Static source file path"
        },
        {
          "$ref": "common.schema.json#/definitions/templateSource"
        }
      ]
    },
    "serviceConfigFileEntry": {
      "type": "object",
      "description": "Plain copied or templated service config file",
      "required": ["source", "destination"],
      "properties": {
        "source": {
          "$ref": "#/definitions/serviceConfigSource"
        },
        "destination": {
          "type": "string",
          "description": "Destination path on target system (absolute path)",
          "not": {
            "pattern": "^/etc/systemd/system/.+"
          }
        }
      },
      "additionalProperties": false
    },
    "serviceConfigDirectoryEntry": {
      "type": "object",
      "description": "Directory to ensure exists for service-owned runtime state",
      "required": ["destination"],
      "properties": {
        "destination": {
          "type": "string",
          "description": "Destination path on target system (absolute path)",
          "not": {
            "pattern": "^/etc/systemd/system/.+"
          }
        },
        "owner": {
          "type": "string",
          "description": "Owner user for managed directories"
        },
        "group": {
          "type": "string",
          "description": "Group for managed directories"
        },
        "mode": {
          "type": "string",
          "pattern": "^0[0-7]{3}$",
          "description": "Directory permissions (e.g., 0750)"
        }
      },
      "not": {
        "required": ["source"]
      },
      "additionalProperties": false
    },
    "serviceConfigEntry": {
      "oneOf": [
        {
          "$ref": "#/definitions/serviceConfigFileEntry"
        },
        {
          "$ref": "#/definitions/serviceConfigDirectoryEntry"
        }
      ]
    }
  },
  "required": ["name", "composition"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Service name (should match directory name)"
    },
    "podman": {
      "type": "object",
      "description": "Podman container/pod runtime configuration",
      "required": ["user", "network"],
      "properties": {
        "user": {
          "type": "string",
          "description": "User to run as (root=rootful, other=rootless)"
        },
        "network": {
          "type": "string",
          "description": "Network mode: ipvlan-l2, host, or container:<name>"
        }
      },
      "additionalProperties": false
    },
    "systemd": {
      "type": "object",
      "description": "Systemd service runtime configuration",
      "required": ["network"],
      "properties": {
        "network": {
          "type": "string",
          "enum": ["service-32", "host"],
          "description": "Network mode: service-32 (dedicated /32) or host"
        }
      },
      "additionalProperties": false
    },
    "apply": {
      "type": "object",
      "description": "Apply-time runtime hints for service-owned config artifacts",
      "properties": {
        "config_change_restart_unit": {
          "type": ["string", "null"],
          "description": "Explicit systemd unit to restart after service.config/service.env updates, or null for static data that should not trigger a service restart"
        }
      },
      "additionalProperties": false
    },
    "composition": {
      "type": "object",
      "required": [],
      "properties": {
        "include": {
          "type": "array",
          "description": "Include composition from other services (e.g., [chrony-common])",
          "items": {"type": "string"}
        },
        "config": {
          "type": "array",
          "description": "Service config/env files and directories to deploy",
          "items": {"$ref": "#/definitions/serviceConfigEntry"}
        },
        "systemd": {
          "type": "array",
          "description": "Systemd units and drop-ins to deploy",
          "items": {"$ref": "common.schema.json#/definitions/systemdEntry"}
        },
        "vault_agent": {
          "type": "object",
          "description": "Vault Agent configuration for secret injection",
          "properties": {
            "base": {
              "description": "Base Vault Agent configuration file",
              "$ref": "common.schema.json#/definitions/configEntry"
            },
            "templates": {
              "type": "array",
              "description": "Vault Agent templates to render",
              "items": {
                "type": "object",
                "required": ["source", "out"],
                "properties": {
                  "source": {
                    "type": "string",
                    "description": "Template source path (.ctmpl file)"
                  },
                  "out": {
                    "type": "string",
                    "description": "Output filename"
                  },
                  "perms": {
                    "type": "string",
                    "pattern": "^0[0-7]{3}$",
                    "description": "File permissions (e.g., 0640)"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "ingress": {
          "type": "object",
          "description": "Caddy ingress/reverse proxy configuration",
          "additionalProperties": {
            "$ref": "common.schema.json#/definitions/ingressDomain"
          }
        },
        "dns": {
          "type": "object",
          "description": "DNS zone configuration for CoreDNS",
          "properties": {
            "zone_files": {
              "type": "array",
              "description": "DNS zone file definitions",
              "items": {
                "$ref": "common.schema.json#/definitions/dnsZoneFile"
              }
            }
          },
          "additionalProperties": false
        },
        "pod": {
          "type": "object",
          "description": "Pod configuration (for podman services with type=pod)",
          "properties": {
            "containers": {
              "type": "array",
              "description": "Container definitions within the pod",
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Container name"
                  },
                  "container": {
                    "description": "Container configuration",
                    "$ref": "common.schema.json#/definitions/containerConfig"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "container": {
          "description": "Container configuration (for podman services with type=container)",
          "$ref": "common.schema.json#/definitions/containerConfig"
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["podman"]
      },
      "then": {
        "properties": {
          "composition": {
            "oneOf": [
              {"required": ["pod"]},
              {"required": ["container"]}
            ]
          }
        }
      }
    },
    {
      "if": {
        "required": ["podman"],
        "properties": {
          "podman": {
            "properties": {
              "user": {"const": "root"}
            }
          }
        }
      },
      "then": {
        "properties": {
          "podman": {
            "properties": {
              "network": {
                "oneOf": [
                  {"enum": ["ipvlan-l2", "host"]},
                  {"pattern": "^container:.+"}
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["podman"],
        "properties": {
          "podman": {
            "properties": {
              "user": {"not": {"const": "root"}}
            }
          }
        }
      },
      "then": {
        "properties": {
          "podman": {
            "properties": {
              "network": {
                "oneOf": [
                  {"enum": ["host"]},
                  {"pattern": "^container:.+"}
                ]
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
