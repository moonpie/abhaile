{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Abhaile Service Schema",
  "description": "Schema for config/services/*/service.yaml - defines service configuration",
  "type": "object",
  "required": ["name", "composition"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Service name (should match directory name)"
    },
    "podman": {
      "type": "object",
      "description": "Podman container/pod runtime configuration",
      "required": ["user", "network"],
      "properties": {
        "user": {
          "type": "string",
          "description": "User to run as (root=rootful, other=rootless)"
        },
        "network": {
          "type": "string",
          "description": "Network mode: ipvlan-l2, host, or container:<name>"
        }
      },
      "additionalProperties": false
    },
    "systemd": {
      "type": "object",
      "description": "Systemd service runtime configuration",
      "required": ["network"],
      "properties": {
        "network": {
          "type": "string",
          "enum": ["service-32", "host"],
          "description": "Network mode: service-32 (dedicated /32) or host"
        }
      },
      "additionalProperties": false
    },
    "composition": {
      "type": "object",
      "required": [],
      "properties": {
        "include": {
          "type": "array",
          "description": "Include composition from other services (e.g., [chrony-common])",
          "items": {"type": "string"}
        },
        "config": {
          "type": "array",
          "description": "Configuration files to deploy",
          "items": {"$ref": "common.schema.json#/definitions/configEntry"}
        },
        "vault_agent": {
          "type": "object",
          "description": "Vault Agent configuration for secret injection",
          "properties": {
            "templates": {
              "type": "array",
              "description": "Vault Agent templates to render",
              "items": {
                "type": "object",
                "required": ["source", "out"],
                "properties": {
                  "source": {
                    "type": "string",
                    "description": "Template source path (.ctmpl file)"
                  },
                  "out": {
                    "type": "string",
                    "description": "Output filename"
                  },
                  "perms": {
                    "type": "string",
                    "pattern": "^0[0-7]{3}$",
                    "description": "File permissions (e.g., 0640)"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "ingress": {
          "type": "object",
          "description": "Caddy ingress/reverse proxy configuration",
          "additionalProperties": {
            "type": "array",
            "description": "Ingress rules for a domain",
            "items": {
              "type": "object",
              "properties": {
                "block": {
                  "type": "string",
                  "description": "Caddy config block file path"
                },
                "base": {
                  "type": "string",
                  "description": "Base Caddyfile path"
                },
                "destination": {
                  "type": "string",
                  "description": "Destination path for Caddyfile"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "pod": {
          "type": "object",
          "description": "Pod configuration (for podman services with type=pod)",
          "properties": {
            "containers": {
              "type": "array",
              "description": "Container definitions within the pod",
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Container name"
                  },
                  "named_volumes": {
                    "type": "array",
                    "description": "Named volumes to mount in this container",
                    "items": {
                      "type": "object",
                      "required": ["name", "host", "mount"],
                      "properties": {
                        "name": {
                          "type": "string",
                          "description": "Volume name"
                        },
                        "host": {
                          "type": "string",
                          "description": "Host path"
                        },
                        "mount": {
                          "type": "string",
                          "description": "Container mount path"
                        },
                        "mode": {
                          "type": "string",
                          "enum": ["ro", "rw"],
                          "description": "Mount mode (ro=read-only, rw=read-write)"
                        },
                        "shared": {
                          "type": "boolean",
                          "description": "Whether volume is shared between containers"
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "mounted_files": {
                    "type": "array",
                    "description": "Individual files to mount",
                    "items": {
                      "type": "object",
                      "required": ["host", "mount"],
                      "properties": {
                        "host": {
                          "type": "string",
                          "description": "Host file path"
                        },
                        "mount": {
                          "type": "string",
                          "description": "Container mount path"
                        },
                        "mode": {
                          "type": "string",
                          "enum": ["ro", "rw"],
                          "description": "Mount mode"
                        }
                      },
                      "additionalProperties": false
                    }
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "container": {
          "type": "object",
          "description": "Container configuration (for podman services with type=container)",
          "properties": {
            "named_volumes": {
              "type": "array",
              "description": "Named volumes to mount",
              "items": {
                "type": "object",
                "required": ["name", "host", "mount"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Volume name"
                  },
                  "host": {
                    "type": "string",
                    "description": "Host path"
                  },
                  "mount": {
                    "type": "string",
                    "description": "Container mount path"
                  },
                  "mode": {
                    "type": "string",
                    "enum": ["ro", "rw"],
                    "description": "Mount mode"
                  },
                  "shared": {
                    "type": "boolean",
                    "description": "Whether volume is shared"
                  }
                },
                "additionalProperties": false
              }
            },
            "mounted_files": {
              "type": "array",
              "description": "Individual files to mount",
              "items": {
                "type": "object",
                "required": ["host", "mount"],
                "properties": {
                  "host": {
                    "type": "string",
                    "description": "Host file path"
                  },
                  "mount": {
                    "type": "string",
                    "description": "Container mount path"
                  },
                  "mode": {
                    "type": "string",
                    "enum": ["ro", "rw"],
                    "description": "Mount mode"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["podman"]
      },
      "then": {
        "properties": {
          "composition": {
            "oneOf": [
              {"required": ["pod"]},
              {"required": ["container"]}
            ]
          }
        }
      }
    },
    {
      "if": {
        "required": ["podman"],
        "properties": {
          "podman": {
            "properties": {
              "user": {"const": "root"}
            }
          }
        }
      },
      "then": {
        "properties": {
          "podman": {
            "properties": {
              "network": {
                "oneOf": [
                  {"enum": ["ipvlan-l2", "host"]},
                  {"pattern": "^container:.+"}
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["podman"],
        "properties": {
          "podman": {
            "properties": {
              "user": {"not": {"const": "root"}}
            }
          }
        }
      },
      "then": {
        "properties": {
          "podman": {
            "properties": {
              "network": {
                "oneOf": [
                  {"enum": ["host"]},
                  {"pattern": "^container:.+"}
                ]
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
