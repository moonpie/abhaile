{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Abhaile Host Schema",
  "description": "Schema for config/hosts/<host>/host.yaml",
  "type": "object",
  "required": ["name", "composition"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Host identifier (e.g., phobos, deimos, common)"
    },
    "physical_device": {
      "type": "string",
      "description": "Primary physical network device name"
    },
    "composition": {
      "type": "object",
      "required": ["software", "user_management"],
      "properties": {
        "include": {
          "type": "array",
          "description": "Include composition from other hosts (e.g., [common])",
          "items": {"type": "string"}
        },
        "config": {
          "type": "array",
          "description": "Configuration files to deploy (static, templated, or directories)",
          "items": {"$ref": "#/definitions/hostConfigEntry"}
        },
        "systemd": {
          "type": "array",
          "description": "Host-owned systemd units and drop-ins to deploy",
          "items": {"$ref": "common.schema.json#/definitions/systemdEntry"}
        },
        "software": {"$ref": "#/definitions/software"},
        "user_management": {"$ref": "#/definitions/userManagement"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "definitions": {
    "hostConfigSource": {
      "oneOf": [
        {
          "type": "string",
          "description": "Static source file path"
        },
        {
          "$ref": "common.schema.json#/definitions/templateSource"
        }
      ]
    },
    "hostConfigFileEntry": {
      "type": "object",
      "description": "Plain copied or templated host config file",
      "required": ["source", "destination"],
      "properties": {
        "source": {
          "$ref": "#/definitions/hostConfigSource"
        },
        "destination": {
          "type": "string",
          "description": "Destination path on target system (absolute path)",
          "not": {
            "pattern": "^/etc/systemd/system/.+"
          }
        }
      },
      "additionalProperties": false
    },
    "hostConfigDirectoryEntry": {
      "type": "object",
      "description": "Directory to ensure exists for host-owned files",
      "required": ["destination"],
      "properties": {
        "destination": {
          "type": "string",
          "description": "Destination path on target system (absolute path)",
          "not": {
            "pattern": "^/etc/systemd/system/.+"
          }
        }
      },
      "not": {
        "required": ["source"]
      },
      "additionalProperties": false
    },
    "hostConfigEntry": {
      "oneOf": [
        {
          "$ref": "#/definitions/hostConfigFileEntry"
        },
        {
          "$ref": "#/definitions/hostConfigDirectoryEntry"
        }
      ]
    },
    "software": {
      "type": "object",
      "properties": {
        "packages": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "downloads": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "builds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "commands": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "userManagement": {
      "type": "object",
      "description": "User/group definitions merge across composition.include by name; scalar fields must match if redefined, list fields are unioned.",
      "properties": {
        "users": {
          "type": "object",
          "additionalProperties": {"$ref": "#/definitions/user"}
        },
        "groups": {
          "type": "object",
          "additionalProperties": {"$ref": "#/definitions/group"}
        },
        "sudoers": {
          "type": "array",
          "items": {"$ref": "#/definitions/sudoer"}
        }
      },
      "additionalProperties": false
    },
    "user": {
      "type": "object",
      "properties": {
        "uid": {"type": "integer"},
        "system": {"type": "boolean"},
        "primary_group": {"type": "string"},
        "additional_groups": {
          "type": "array",
          "items": {"type": "string"}
        },
        "home": {"type": "string"},
        "shell": {"type": "string"},
        "gecos": {"type": "string"},
        "ssh_authorized_keys": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "group": {
      "type": "object",
      "required": ["gid"],
      "properties": {
        "gid": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "sudoer": {
      "type": "object",
      "required": ["name", "rules"],
      "properties": {
        "name": {"type": "string"},
        "rules": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    }
  }
}
