{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Abhaile Common Schema Definitions",
  "description": "Shared schema definitions used across host.schema.json and service.schema.json",
  "definitions": {
    "templateSource": {
      "type": "object",
      "description": "Jinja2 template source with optional variables",
      "required": ["template"],
      "properties": {
        "template": {
          "type": "string",
          "description": "Relative path to Jinja2 template (e.g., 'common/systemd-resolved/resolved.conf.j2')"
        },
        "variables": {
          "type": "object",
          "description": "Explicit template variables (optional, context is provided automatically)",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "fileEntrySource": {
      "description": "Source file path (static) or template object",
      "oneOf": [
        {
          "type": "string",
          "description": "Static source file path"
        },
        {
          "$ref": "#/definitions/templateSource"
        }
      ]
    },
    "fileSourceDestinationEntry": {
      "type": "object",
      "description": "Reusable file entry shape with required source and destination",
      "required": ["source", "destination"],
      "properties": {
        "source": {
          "$ref": "#/definitions/fileEntrySource"
        },
        "destination": {
          "type": "string",
          "description": "Destination path on target system (absolute path)"
        }
      }
    },
    "configFileEntry": {
      "description": "Static or templated configuration file with source and destination",
      "allOf": [
        {
          "$ref": "#/definitions/fileSourceDestinationEntry"
        },
        {
          "type": "object",
          "required": ["source", "destination"],
          "properties": {
            "source": {
              "$ref": "#/definitions/fileEntrySource"
            },
            "destination": {
              "type": "string",
              "description": "Destination path on target system (absolute path)"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "configDirectoryEntry": {
      "type": "object",
      "description": "Directory to ensure exists (destination only, no source)",
      "required": ["destination"],
      "properties": {
        "destination": {
          "type": "string",
          "description": "Destination path on target system (absolute path)"
        }
      },
      "not": {
        "required": ["source"]
      },
      "additionalProperties": false
    },
    "configEntry": {
      "description": "Configuration file entry: static file, template, or directory to ensure exists",
      "oneOf": [
        {
          "$ref": "#/definitions/configFileEntry"
        },
        {
          "$ref": "#/definitions/configDirectoryEntry"
        }
      ]
    },
    "systemdEntry": {
      "description": "Systemd unit or drop-in file managed explicitly from composition.systemd",
      "allOf": [
        {
          "$ref": "#/definitions/fileSourceDestinationEntry"
        },
        {
          "type": "object",
          "required": ["source", "destination"],
          "properties": {
            "source": {
              "$ref": "#/definitions/fileEntrySource"
            },
            "destination": {
              "type": "string",
              "pattern": "^/etc/systemd/system/.+",
              "description": "Destination path under /etc/systemd/system/"
            },
            "enable": {
              "type": "boolean",
              "description": "Whether apply should enable the unit for boot persistence"
            },
            "start": {
              "type": "boolean",
              "description": "Whether apply should start the unit after writes"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "namedVolume": {
      "type": "object",
      "description": "Named volume definition for containers",
      "required": ["name", "host_path", "mount_path"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Volume name"
        },
        "host_path": {
          "type": "string",
          "description": "Host path"
        },
        "mount_path": {
          "type": "string",
          "description": "Container mount path"
        },
        "mode": {
          "type": "string",
          "enum": ["ro", "rw"],
          "description": "Mount mode (ro=read-only, rw=read-write)"
        },
        "shared": {
          "type": "boolean",
          "description": "Whether volume is shared between containers"
        }
      },
      "additionalProperties": false
    },
    "mountedFile": {
      "type": "object",
      "description": "Individual file mount definition for containers",
      "required": ["host_path", "mount_path"],
      "properties": {
        "host_path": {
          "type": "string",
          "description": "Host file path"
        },
        "mount_path": {
          "type": "string",
          "description": "Container mount path"
        },
        "mode": {
          "type": "string",
          "enum": ["ro", "rw"],
          "description": "Mount mode"
        }
      },
      "additionalProperties": false
    },
    "ingressDomain": {
      "type": "object",
      "description": "Ingress configuration for a domain",
      "properties": {
        "base": {
          "description": "Base Caddyfile configuration",
          "$ref": "#/definitions/configEntry"
        },
        "blocks": {
          "type": "array",
          "description": "Additional Caddy config block file paths",
          "items": {
            "type": "string",
            "description": "Path to Caddy config block file"
          }
        }
      },
      "additionalProperties": false
    },
    "dnsZoneFile": {
      "type": "object",
      "description": "DNS zone file definition",
      "required": ["zone", "file"],
      "properties": {
        "zone": {
          "type": "string",
          "description": "DNS zone name (e.g., 'example.com' or '*' for catch-all)"
        },
        "file": {
          "description": "Zone file configuration",
          "$ref": "#/definitions/configEntry"
        }
      },
      "additionalProperties": false
    },
    "containerConfig": {
      "type": "object",
      "description": "Container volume and mount configuration",
      "properties": {
        "named_volumes": {
          "type": "array",
          "description": "Named volumes to mount",
          "items": {
            "$ref": "#/definitions/namedVolume"
          }
        },
        "mounted_files": {
          "type": "array",
          "description": "Individual files to mount",
          "items": {
            "$ref": "#/definitions/mountedFile"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
