{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Abhaile Host Software Action Schema",
  "description": "Schema for config/hosts/<host>/software/{downloads,builds,commands}/*.yaml",
  "type": "object",
  "required": ["id", "name", "commands"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
