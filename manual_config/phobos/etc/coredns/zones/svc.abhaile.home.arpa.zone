$ORIGIN svc.abhaile.home.arpa.
$TTL 300

@   IN SOA ns1.abhaile.home.arpa. hostmaster.abhaile.home.arpa. (
        2025110901
        7200
        3600
        1209600
        3600 )
    IN NS ns1.abhaile.home.arpa.
    IN NS ns2.abhaile.home.arpa.

; ----- Ingress / identity / core -----
caddy-internal      IN A 172.20.20.200
authelia            IN A 172.20.20.201
homepage            IN A 172.20.20.202
netbox              IN A 172.20.20.203
vault               IN A 172.20.20.204
vaultwarden         IN A 172.20.20.205
postfix             IN A 172.20.20.206
crowdsec            IN A 172.20.20.207

; Omada controller container
omada-controller    IN A 172.20.20.220

; DMZ Caddy (ipvlan-l2)
caddy-dmz           IN A 172.20.100.200

; ----- DNS / NTP service IPs (host-bound, via shim) -----
dns-filtered        IN A 172.20.20.235
dns-clean           IN A 172.20.20.236
ntp-a               IN A 172.20.20.237
ntp-b               IN A 172.20.20.238

; ----- Observability -----
prometheus          IN A 172.20.20.210
alertmanager        IN A 172.20.20.211
grafana             IN A 172.20.20.212
blackbox            IN A 172.20.20.213
snmp-exporter       IN A 172.20.20.214
uptime-kuma         IN A 172.20.20.215
librespeed          IN A 172.20.20.216
smokeping           IN A 172.20.20.217
loki                IN A 172.20.20.218

; ----- Home automation / IoT -----
homeassistant       IN A 172.20.20.221
mosquitto           IN A 172.20.20.222
zigbee2mqtt         IN A 172.20.20.223
esphome             IN A 172.20.20.224
go2rtc              IN A 172.20.20.225
frigate             IN A 172.20.20.226

; ----- Media / downloads -----
gluetun             IN A 172.20.20.239
qbittorrent         IN A 172.20.20.239

immich              IN A 172.20.20.240
jellyfin            IN A 172.20.20.241
tdarr               IN A 172.20.20.242
radarr              IN A 172.20.20.243
sonarr              IN A 172.20.20.244
lidarr              IN A 172.20.20.245
readarr             IN A 172.20.20.246
bazarr              IN A 172.20.20.247
prowlarr            IN A 172.20.20.248
jellyseerr          IN A 172.20.20.249
flaresolverr        IN A 172.20.20.250

; Extend with any missing services as needed.
