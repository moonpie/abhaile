[Unit]
Description=Unseal Vault using SOPS file
After=vault.service network-online.target
Wants=vault.service

[Service]
Type=oneshot
Environment=HOME=/root
Environment=XDG_CONFIG_HOME=/root/.config
Environment=SOPS_AGE_KEY_FILE=/root/.config/sops/age/keys.txt
Environment=VAULT_ADDR=http://172.20.20.204:8200
ExecStart=/opt/abhaile/tools/bash/vault_unseal.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
