# generated by vault-agent (do not edit by hand)
log:
  level: info

theme: auto

server:
  address: tcp://0.0.0.0:9091

authentication_backend:
  file:
    path: /config/users_database.yml
    password:
      algorithm: argon2id

session:
  secret: "{{ with secret "secret/data/abhaile/authelia" -}}{{ .Data.data.session_secret }}{{- end }}"
  cookies:
    - name: authelia_session
      domain: abhaile.home.arpa
      authelia_url: https://authelia.abhaile.home.arpa
      default_redirection_url: https://authelia.abhaile.home.arpa/
      same_site: lax
      expiration: 1h
      inactivity: 15m
      remember_me: 1M

  redis:
    host: 127.0.0.1
    port: 6379
    password: "{{ with secret "secret/data/abhaile/redis" -}}{{ .Data.data.password }}{{- end }}"

storage:
  local:
    path: /data/db.sqlite3
  encryption_key: "{{ with secret "secret/data/abhaile/authelia" -}}{{ .Data.data.storage_encryption_key }}{{- end }}"

# No SMTP for now: filesystem notifier satisfies schema.
notifier:
  filesystem:
    filename: /data/notifications

identity_validation:
  reset_password:
    jwt_secret: "{{ with secret "secret/data/abhaile/authelia" -}}{{ .Data.data.jwt_secret }}{{- end }}"

access_control:
  default_policy: deny
  rules:
    - domain: vault.abhaile.home.arpa
      policy: one_factor
      subject:
        - group:admins
