# deSEC DNS API token for Caddy-DMZ
# Encrypted with: sops -e secrets/caddy-dmz-desec.sops.yaml
# Decrypted to: /etc/abhaile/caddy-dmz-desec/caddy-dmz-desec.env

# deSEC API token (used by Caddy DNS-01 plugin for ACME challenges)
# Obtain from: https://desec.io/account/tokens/
DESEC_TOKEN="placeholder-replace-with-actual-desec-token"

# Optional: deSEC domain name (if not using default)
# DESEC_DOMAIN="abhaile.dedyn.io"
