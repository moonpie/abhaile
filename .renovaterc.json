{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "schedule": ["after 09:00 and before 17:00 on Monday"],
  "prConcurrentLimit": 3,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "major"],
      "automerge": false
    }
  ],
  "pip_requirements": {
    "fileMatch": ["^requirements\\.txt$"]
  },
  "regexManagers": [
    {
      "fileMatch": ["^config/services/.*/quadlets/.*\\.image$"],
      "matchStrings": ["Image=(?<depName>.*?):(?<currentValue>.*?)\\s"],
      "datasourceTemplate": "docker"
    }
  ],
  "dockerfile": {
    "enabled": true
  }
}
