[Unit]
Description=Vault Agent (rootless, templates)
After=network-online.target
Wants=network-online.target

[Container]
Image={{ image }}
Network=host
Timezone=local
{% for v in volume_lines %}
{{ v }}
{% endfor %}
Entrypoint=/bin/vault
Exec=agent -config=/agent/config.hcl

[Service]
Restart=on-failure
RestartSec=3s

[Install]
WantedBy=multi-user.target
