# CoreDNS Configuration
# Bind Address: {{ service.config.bind_ip }}
# Forward To: {{ service.config.forward_to }}

{% for zone in network.dns.zones if zone.provider.name == 'coredns-common' %}
# ----- Authoritative: {{ zone.name.rstrip('.') }} -----
{{ zone.name.rstrip('.') }}:53 {
    bind {{ service.config.bind_ip }}

    log
    errors

    file /etc/coredns/zones/{{ zone.name.rstrip('.') }}.zone

    # Omada dynamic client/device/DHCP records
    # URL/site and credentials come from /etc/coredns/omada.env.
    omada {
        controller_url ${OMADA_URL}
        site ${OMADA_SITE}
        username ${OMADA_USERNAME}
        password ${OMADA_PASSWORD}
        resolve_clients true
        resolve_devices true
        resolve_dhcp_reservations true
        stale_record_duration 24h
        ignore_startup_errors true
        fallthrough
    }
}
{% endfor %}
# ----- Default recursive resolver -----
.:53 {
    bind {{ service.config.bind_ip }}

    log
    errors

    # Internal override for *.abhaile.dedyn.io A records:
    # - Only affects IN A.
    # - TXT/SOA/other types fall through to upstream.
    template IN A abhaile.dedyn.io {
        match ^(.*\.)?abhaile\.dedyn\.io\.$
        answer "{{ '{{ ' }}.Name{{ ' }}' }} 60 IN A {{ service.config.dmz_caddy_ip }}"
        fallthrough
    }

    # Forward everything else
    forward . {{ service.config.forward_to }} {
        force_tcp
    }

    cache 300
}
