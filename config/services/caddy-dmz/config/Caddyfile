	redir https://{host}{uri} 308
}

# Test host: proves DNS-01 + TLS + routing
test.abhaile.dedyn.io {
#	bind 172.20.100.200
	import common_headers
	import dns01_desec
	respond "dmz caddy ok" 200
}

# --- Default wildcard posture (closed-by-default) ---
*.abhaile.dedyn.io {
#	bind 172.20.100.200
	import common_headers
	import dns01_desec
	respond "Not Found" 404
}
