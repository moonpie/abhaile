    blocky    IN CNAME blocky.svc.abhaile.home.arpa.
    caddy    IN CNAME caddy-internal.svc.abhaile.home.arpa.
    ca    IN CNAME caddy.abhaile.home.arpa.
    test    IN CNAME caddy.abhaile.home.arpa.
    vault    IN CNAME caddy.abhaile.home.arpa.
    authelia    IN CNAME caddy.abhaile.home.arpa.
    login    IN CNAME authelia.abhaile.home.arpa.
    omada    IN CNAME caddy.abhaile.home.arpa.
    ntp-b    IN CNAME chrony-b.svc.abhaile.home.arpa.
    ns2    IN CNAME coredns-clean.svc.abhaile.home.arpa.
