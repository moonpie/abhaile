        3600       ; retry
        1209600    ; expire
        3600 )     ; minimum
    IN NS ns1.abhaile.home.arpa.
    IN NS ns2.abhaile.home.arpa.


    phobos    IN CNAME phobos.svc.abhaile.home.arpa.
