# CoreDNS Configuration
# Bind Address: 172.20.20.236
# Forward To: 9.9.9.9 149.112.112.112 1.1.1.1 1.0.0.1

# ----- Authoritative: abhaile.home.arpa -----
abhaile.home.arpa:53 {
    bind 172.20.20.236

    log
    errors

    file /etc/coredns/zones/abhaile.home.arpa.zone

    # Omada dynamic client/device/DHCP records
    # Uses direct IP to avoid DNS bootstrap/circular deps.
    omada {
        controller_url https://172.20.20.220:8043
        site .*
        username ${OMADA_USERNAME}
        password ${OMADA_PASSWORD}
        resolve_clients true
        resolve_devices true
        resolve_dhcp_reservations true
        stale_record_duration 24h
        ignore_startup_errors true
    }
}
