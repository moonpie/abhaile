# ----- Default recursive resolver -----
.:53 {
    bind 172.20.20.236

    log
    errors

    # Internal override for *.abhaile.dedyn.io A records:
    # - Only affects IN A.
    # - TXT/SOA/other types fall through to upstream.
    template IN A abhaile.dedyn.io {
        match ^(.*\.)?abhaile\.dedyn\.io\.$
        answer "{{ .Name }} 60 IN A 172.20.100.200"
        fallthrough
    }

    # Forward everything else
    forward . 9.9.9.9 149.112.112.112 1.1.1.1 1.0.0.1 {
        force_tcp
    }

    cache 300
}
